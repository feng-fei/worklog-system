<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>瑞翼工作台</title>
<link rel="manifest" href="manifest.json?v=20260620-pwa1">
<meta name="theme-color" content="#eef7f4" media="(prefers-color-scheme: light)">
<meta name="theme-color" content="#030b10" media="(prefers-color-scheme: dark)">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<link rel="apple-touch-icon" href="icon-192.png">
<link href="css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="fonts/bootstrap-icons.css">
<link rel="stylesheet" href="style-app.css?v=20260714-linear-v22">
</head>
<body class="app-v3">
<a class="skip-link" href="#mainContent">跳到主内容</a>

<!-- ====== 登录页面 ====== -->
<div id="loginPage" class="d-flex align-items-center justify-content-center">
<div class="card shadow-lg is-8">
<div class="card-body p-4">
<div class="text-center mb-4">
<i class="bi bi-journal-bookmark-fill fs-1 is-9"></i>
<h4 class="fw-bold mt-2" id="loginCompanyName"></h4>
<p class="text-muted small">工作记录管理系统</p>
</div>
<form id="loginForm">
<div class="mb-3">
<label class="form-label fw500">用户名</label>
<div class="input-group">
<span class="input-group-text"><i class="bi bi-person" aria-hidden="true"></i></span>
<input type="text" class="form-control" id="loginUsername" name="username" placeholder="请输入用户名…" autocomplete="username" spellcheck="false" required>
</div>
</div>
<div class="mb-3">
<label class="form-label fw500">密码</label>
<div class="input-group">
<span class="input-group-text"><i class="bi bi-lock" aria-hidden="true"></i></span>
<input type="password" class="form-control" id="loginPassword" name="password" placeholder="请输入密码…" autocomplete="current-password" required>
</div>
</div>
<div class="text-danger small mb-3 is-0" id="loginError" aria-live="polite"></div>
<button type="submit" class="btn btn-primary w-100 py-2 fw-semibold"><i class="bi bi-box-arrow-in-right me-1"></i> 登录</button>
</form>
<div class="text-center mt-3 text-muted is-10">联系管理员获取账号</div>
</div>
</div>
</div>

<!-- ====== 主应用 ====== -->
<div id="appContent" class="ry-app-shell is-0">

<!-- 顶部导航 -->
<nav class="navbar navbar-light navbar-expand-lg sticky-top ry-appbar" aria-label="主导航">
<div class="container-fluid px-3">
<a class="navbar-brand d-flex align-items-center gap-2" href="#">
<i class="bi bi-journal-bookmark-fill fs-4" aria-hidden="true"></i>
<span class="text-nowrap fw-bold is-11" id="companyTitle">瑞翼工作台</span>
</a>
<button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-label="打开导航菜单"><span class="navbar-toggler-icon"></span></button>
<div class="collapse navbar-collapse" id="navMenu">
<ul class="navbar-nav ms-auto gap-1">
<li class="nav-item"><a class="nav-link" onclick="switchTab('tab-dashboard')" role="tab"><i class="bi bi-speedometer2 me-1"></i>工作台</a></li>
<li class="nav-item dropdown">
<a class="nav-link" href="#" id="businessDropdown" role="button" data-bs-toggle="dropdown"><i class="bi bi-grid-1x2 me-1"></i>业务</a>
<ul class="dropdown-menu dropdown-menu-end ry-nav-menu">
<li><h6 class="dropdown-header">新增与处理</h6></li>
<li><a class="dropdown-item" href="#" onclick="openNewWork('construction')"><i class="bi bi-tools me-2"></i>施工记录</a></li>
<li><a class="dropdown-item" href="#" onclick="openNewWork('repair')"><i class="bi bi-wrench-adjustable me-2"></i>维修工单</a></li>
<li><a class="dropdown-item" href="#" onclick="switchTab('tab-pending')"><i class="bi bi-clock-history me-2"></i>报修待办 <span class="badge bg-danger rounded-pill ms-1 is-12" id="pendingBadge">0</span></a></li>
</ul>
</li>
<li class="nav-item dropdown">
<a class="nav-link" href="#" id="insightDropdown" role="button" data-bs-toggle="dropdown"><i class="bi bi-bar-chart-line me-1"></i>查询统计</a>
<ul class="dropdown-menu dropdown-menu-end ry-nav-menu">
<li><h6 class="dropdown-header">查询</h6></li>
<li><a class="dropdown-item" href="#" onclick="switchTab('tab-query')"><i class="bi bi-search me-2"></i>工单查询</a></li>
<li><a class="dropdown-item" href="#" onclick="switchTab('tab-calendar')"><i class="bi bi-calendar3 me-2"></i>日历视图</a></li>
<li><hr class="dropdown-divider"></li>
<li><h6 class="dropdown-header">统计</h6></li>
<li><a class="dropdown-item" href="#" onclick="switchTab('tab-stats')"><i class="bi bi-graph-up me-2"></i>经营统计</a></li>
</ul>
</li>
<li class="nav-item dropdown">
<a class="nav-link" href="#" id="manageDropdown" role="button" data-bs-toggle="dropdown"><i class="bi bi-folder2-open me-1"></i>管理</a>
<ul class="dropdown-menu dropdown-menu-end ry-nav-menu">
<li><h6 class="dropdown-header">资料</h6></li>
<li><a class="dropdown-item" href="#" onclick="switchTab('tab-customer')"><i class="bi bi-people me-2"></i>客户</a></li>
<li><a class="dropdown-item" href="#" onclick="switchTab('tab-staff')"><i class="bi bi-person-badge me-2"></i>员工</a></li>
<li><a class="dropdown-item" href="#" onclick="switchTab('tab-salary')"><i class="bi bi-cash-coin me-2"></i>工资</a></li>
</ul>
</li>

<li class="nav-item dropdown">
<a class="nav-link" href="#" id="settingsDropdown" role="button" data-bs-toggle="dropdown"><i class="bi bi-gear me-1"></i>设置</a>
<ul class="dropdown-menu dropdown-menu-end">
<li><span class="dropdown-item-text text-muted small" id="dropdownUserInfo"></span></li>
<li><hr class="dropdown-divider"></li>
<li><a class="dropdown-item" href="#" onclick="toggleTheme(); return false;"><i class="bi bi-moon-stars me-2" id="themeToggleIcon"></i><span id="themeToggleText">深色模式</span></a></li>
<li><hr class="dropdown-divider"></li>
<li><a class="dropdown-item" href="#" onclick="showChangePasswordModal()"><i class="bi bi-key me-2"></i>修改密码</a></li>
<li><a class="dropdown-item" href="#" onclick="showBackupModal()"><i class="bi bi-cloud-arrow-down me-2"></i>数据备份</a></li>
<li id="oplogMenuLink"><a class="dropdown-item" href="#" onclick="switchTab('tab-oplogs')"><i class="bi bi-clock-history me-2"></i>操作日志</a></li>
<li><hr class="dropdown-divider"></li>
<li><a class="dropdown-item text-danger" href="#" onclick="doLogout()"><i class="bi bi-box-arrow-right me-2"></i>退出登录</a></li>
</ul>
</li>
</ul>
</div></div></nav>



<main class="tab-content ry-main" id="mainContent">

<!-- ====== 工作记录 ====== -->
<div class="tab-pane fade" id="tab-work">
<div class="container py-3">
<div class="card card-accent-green shadow-sm mb-3">
<div class="card-header d-flex align-items-center gap-2"><i class="bi bi-plus-circle-fill"></i><span class="fw-semibold">新增施工 / 维修记录</span></div>
<div class="card-body">
<form id="workForm" enctype="multipart/form-data">
<div class="row g-3">
<div class="col-md-6">
<label class="form-label fw500">客户 <span class="text-danger">*</span></label>
<div class="input-group">
<div class="customer-select-wrap">
<input type="text" class="form-control" id="woCustomerName" name="customer_name" required autocomplete="off" placeholder="输入或选择" oninput="showCustomerDropdown(this)" onfocus="showCustomerDropdown(this)">
<div class="customer-dropdown" id="customerDropdown"></div>
</div>
<button type="button" class="btn btn-outline-primary" onclick="openCustomerQuickAdd('work')" title="添加客户" aria-label="添加客户"><i class="bi bi-plus-lg" aria-hidden="true"></i></button>
</div>
<input type="hidden" name="customer_phone" id="woCustomerPhone">
</div>
<div class="col-md-3">
<label class="form-label fw500">联系人</label>
<input type="text" class="form-control" name="contact_name" id="woContactName" placeholder="自动填入">
</div>
<div class="col-md-3">
<label class="form-label fw500">联系电话</label>
<input type="text" class="form-control" id="woCustomerPhoneVisible" placeholder="自动填入" oninput="document.getElementById('woCustomerPhone').value=this.value">
</div>
<!-- 记录类型切换 -->
<div class="col-12">
<div class="d-flex gap-3 mb-2 align-items-center">
<label class="form-label fw500 me-1 mb-0">记录类型</label>
<div class="d-flex gap-3" role="group">
<input type="radio" class="btn-check" name="record_type" id="rtConstruction" value="construction" checked onchange="toggleRecordType()">
<label class="btn-capsule" for="rtConstruction">
<i class="bi bi-tools me-1"></i>施工
</label>
<input type="radio" class="btn-check" name="record_type" id="rtRepair" value="repair" onchange="toggleRecordType()">
<label class="btn-capsule" for="rtRepair">
<i class="bi bi-gear me-1"></i>维修
</label>
</div>
</div>
</div>



<div class="col-md-6">
<label class="form-label fw500">工作人员 <span class="text-danger">*</span></label>
<div id="staffPicker" class="staff-picker">
    <button type="button" id="staffPickerTrigger" class="staff-picker-trigger" onclick="toggleStaffPicker()" aria-expanded="false" aria-controls="staffPickPanel">
        <i class="bi bi-people-fill"></i> 选择人员 <i class="bi bi-chevron-down ms-1 is-1"></i>
    </button>
    <div id="staffPickPanel" class="staff-pick-panel"></div>
</div>
<div id="selectedStaffTags" class="d-flex flex-wrap gap-1 mt-1"></div>
<small class="text-muted">点击上方选择框选取，临时工请填下方工时和日薪</small>
<input type="hidden" name="staff_names" id="woStaffNames">
<input type="hidden" name="temp_staff_details" id="woTempStaffDetails" value="[]">
</div>
<div class="col-12 is-0" id="woTempStaffFields">
<div class="card bg-light p-2">
<div class="row g-2 align-items-end">
<div class="col-12"><strong class="small">临时工作人员工时录入</strong></div>
<div id="woTempStaffRows"></div>
</div></div></div>
<div class="col-md-6 mobile-half">
<label class="form-label fw500">状态</label>
<select class="form-select" name="status" id="woStatus"></select>
</div>
<div class="col-md-6 mobile-half">
<label class="form-label fw500" id="woSubtypeLabel">施工类型</label>
<select class="form-select" name="work_subtype" id="woSubtype"></select>
</div>
<div class="col-md-6 mobile-half">
<label class="form-label fw500">已收金额</label>
<input type="number" class="form-control" name="paid_amount" min="0" step="0.01" value="0">
</div>
<div class="col-md-6 mobile-half"><label class="form-label fw500">收款状态</label>
<select class="form-select" name="payment_status" id="woPaymentStatus"><option value="unpaid">未收款</option><option value="partial">部分收款</option><option value="paid">已收款</option><option value="monthly">月结</option><option value="invoicing">待开票</option><option value="invoiced">已开票</option></select>
</div>
<div class="col-md-6">
<label class="form-label fw500">地址</label>
<input type="text" class="form-control" name="work_address" id="woWorkAddress" placeholder="自动填入">
</div>
<div class="col-md-3">
<label class="form-label fw500">开始</label>
<input type="time" class="form-control" name="start_time" onchange="calcAutoLaborFee()">
</div>
<div class="col-md-3">
<label class="form-label fw500">结束</label>
<input type="time" class="form-control" name="end_time" onchange="calcAutoLaborFee()">
</div>

<!-- 施工内容 -->
<div id="constructionFields">
<div class="col-12">
<label class="form-label fw500">施工内容 <span class="text-danger">*</span></label>
<textarea class="form-control" name="work_content" rows="3"></textarea>
</div>
</div>

<!-- 维修内容 -->
<div id="repairFields">
<!-- 服务类别 -->
<div class="col-md-3">
<label class="form-label fw500">服务类别</label>
<select class="form-select" name="service_category">
<option value="">请选择</option>
<option value="维修">维修</option>
<option value="新装">新装</option>
<option value="保养">保养</option>
<option value="巡检">巡检</option>
<option value="移机">移机</option>
</select>
</div>
<!-- 保修情况 -->
<div class="col-md-3">
<label class="form-label fw500">保修情况</label>
<select class="form-select" name="warranty_status">
<option value="">请选择</option>
<option value="在保">在保</option>
<option value="过保">过保</option>
<option value="无保">无保</option>
</select>
</div>
<!-- 优先级 -->
<div class="col-md-3">
<label class="form-label fw500">优先级</label>
<select class="form-select" name="priority">
<option value="low">低</option>
<option value="normal" selected>普通</option>
<option value="high">高</option>
<option value="urgent">紧急</option>
</select>
</div>
<!-- 保修天数 -->
<div class="col-md-3">
<label class="form-label fw500">保修天数</label>
<input type="number" class="form-control" name="warranty_days" min="0" value="0" placeholder="如：90">
</div>
<!-- 到达/完工时间 -->
<div class="col-md-3">
<label class="form-label fw500">到达时间</label>
<input type="time" class="form-control" name="arrival_time">
</div>
<div class="col-md-3">
<label class="form-label fw500">完工时间</label>
<input type="time" class="form-control" name="completion_time">
</div>
<!-- 勘查/报价时间 -->
<div class="col-md-3">
<label class="form-label fw500">勘查时间</label>
<input type="time" class="form-control" name="survey_time">
</div>
<div class="col-md-3">
<label class="form-label fw500">报价时间</label>
<input type="time" class="form-control" name="quote_time">
</div>
<div class="col-md-3">
<label class="form-label fw500">维修开始</label>
<input type="time" class="form-control" name="repair_start_time">
</div>
<div class="col-md-3">
<label class="form-label fw500">维修结束</label>
<input type="time" class="form-control" name="repair_end_time">
</div>
<div class="col-md-3">
<label class="form-label fw500">验收时间</label>
<input type="time" class="form-control" name="accept_time">
</div>
<!-- 设备信息 -->
<div class="col-md-4">
<label class="form-label fw500">设备品牌</label>
<input type="text" class="form-control" name="device_brand" placeholder="如：海康威视">
</div>
<div class="col-md-4">
<label class="form-label fw500">设备型号</label>
<input type="text" class="form-control" name="device_model" placeholder="如：DS-2CD2T47G2-L">
</div>
<div class="col-md-4">
<label class="form-label fw500">设备序列号</label>
<input type="text" class="form-control" name="device_sn" placeholder="设备SN号">
</div>
<!-- 涉及系统/设备（系统级维修） -->
<div class="col-12">
<label class="form-label fw500">涉及系统/设备</label>
<textarea class="form-control" name="involved_systems" rows="2" placeholder="如：1楼监控摄像头（海康威视 DS-2CD2T47G2-L）、2楼门禁系统、停车场道闸等"></textarea>
<small class="text-muted">可填写多个设备或系统，用逗号或换行分隔</small>
</div>
<!-- 故障现象 -->
<div class="col-12">
<label class="form-label fw500">故障现象</label>
<textarea class="form-control" name="fault_phenomenon" rows="2" placeholder="描述出现的故障现象"></textarea>
</div>
<!-- 故障描述 -->
<div class="col-12">
<label class="form-label fw500">故障描述（详细说明）</label>
<textarea class="form-control" name="fault_description" rows="2" placeholder="详细描述故障情况"></textarea>
</div>
<!-- 故障原因 -->
<div class="col-12">
<label class="form-label fw500">故障原因</label>
<textarea class="form-control" name="fault_cause" rows="2" placeholder="分析故障产生的原因"></textarea>
</div>
<!-- 故障诊断 -->
<div class="col-12">
<label class="form-label fw500">故障诊断</label>
<textarea class="form-control" name="fault_diagnosis" rows="2" placeholder="诊断过程和结论"></textarea>
</div>
<!-- 维修方案 -->
<div class="col-12">
<label class="form-label fw500">维修方案</label>
<textarea class="form-control" name="repair_solution" rows="2" placeholder="制定的维修方案"></textarea>
</div>
<!-- 维修过程 -->
<div class="col-12">
<label class="form-label fw500">维修过程</label>
<textarea class="form-control" name="repair_process" rows="3" placeholder="填写维修步骤和方法"></textarea>
</div>
<!-- 维修结果 -->
<div class="col-12">
<label class="form-label fw500">维修结果</label>
<div class="d-flex gap-3">
<div class="form-check">
<input class="form-check-input" type="radio" name="repair_result" id="repairCompleted" value="completed" checked onchange="toggleRepairIncompleteFields()">
<label class="form-check-label" for="repairCompleted">✅ 已维修完成</label>
</div>
<div class="form-check">
<input class="form-check-input" type="radio" name="repair_result" id="repairPending" value="pending" onchange="toggleRepairIncompleteFields()">
<label class="form-check-label" for="repairPending">⏳ 未维修完成（说明原因并转待办）</label>
</div>
</div>
</div>
<!-- 未完成原因（联动显示） -->
<div class="col-12" id="repairIncompleteBox">
<div class="repair-incomplete-box">
<div class="row g-2">
<div class="col-md-4">
<label class="form-label fw500">未完成原因类型</label>
<select class="form-select" name="incomplete_reason_type" id="incompleteReasonType">
<option value="">请选择</option>
<option value="缺少配件">缺少配件</option>
<option value="设备需更换">设备需更换</option>
<option value="客户现场条件不具备">客户现场条件不具备</option>
<option value="需厂家/上级技术支持">需厂家/上级技术支持</option>
<option value="客户改期">客户改期</option>
<option value="费用/报价待确认">费用/报价待确认</option>
<option value="其他原因">其他原因</option>
</select>
</div>
<div class="col-md-8">
<label class="form-label fw500">原因说明 / 后续建议 <span class="text-danger">*</span></label>
<textarea class="form-control" name="incomplete_reason" id="incompleteReason" rows="2" placeholder="例如：摄像头主板损坏，现场无备件，需采购后二次上门更换"></textarea>
</div>
</div>
<small class="text-muted">保存后会自动生成二次上门待办，待办内容会带上未完成原因。</small>
</div>
</div>
</div>
<!-- 客户意见 -->
<div class="col-12">
<label class="form-label fw500">客户意见</label>
<textarea class="form-control" name="customer_feedback" rows="2" placeholder="选填，客户对服务的评价或建议"></textarea>
</div>
<!-- 满意度 -->
<div class="col-md-3">
<label class="form-label fw500">满意度</label>
<select class="form-select" name="satisfaction">
<option value="">请选择</option>
<option value="满意">满意</option>
<option value="比较满意">比较满意</option>
<option value="一般">一般</option>
<option value="不满意">不满意</option>
</select>
</div>
<!-- 设备明细 -->
<div class="col-12">
<div class="equipment-section">
<div class="d-flex align-items-center justify-content-between mb-2">
<label class="form-label fw500 mb-0">设备明细</label>
<button type="button" class="btn btn-sm btn-outline-primary" onclick="addEquipmentRow()">
<i class="bi bi-plus-lg me-1"></i>添加设备
</button>
</div>
<div id="equipmentRows" class="equipment-rows"></div>
<input type="hidden" name="equipment_details" id="equipmentDetails" value="[]">
</div>
</div>
<div class="col-12">
<div class="d-flex align-items-center gap-3 mb-1">
<label class="form-label fw500 mb-0">税费</label>
<div class="form-check form-check-inline">
<input class="form-check-input" type="radio" name="tax_type" id="taxNo" value="no" checked onchange="calcWorkTotal()">
<label class="form-check-label" for="taxNo">不含税</label>
</div>
<div class="form-check form-check-inline">
<input class="form-check-input" type="radio" name="tax_type" id="taxYes" value="tax" onchange="calcWorkTotal()">
<label class="form-check-label" for="taxYes">含增值税 <span id="taxRateDisplay">3%</span></label>
</div>
<input type="hidden" name="tax_rate" id="taxRate" value="0.03">
</div>
</div>
<div class="col-md-3"><label class="form-label fw500">人工 (¥)</label><input type="number" class="form-control" name="labor_fee" step="0.01" min="0" value="0" onchange="calcWorkTotal()"></div>
<div class="col-md-3"><label class="form-label fw500">材料 (¥)</label><input type="number" class="form-control" name="material_fee" step="0.01" min="0" value="0" onchange="calcWorkTotal()"></div>
<div class="col-md-3"><label class="form-label fw500">设备费 (¥)</label><input type="number" class="form-control" name="equipment_fee_total" step="0.01" min="0" value="0" onchange="calcWorkTotal()"></div>
<div class="col-md-3"><label class="form-label fw500">调试费 (¥)</label><input type="number" class="form-control" name="debug_fee" step="0.01" min="0" value="0" onchange="calcWorkTotal()"></div>
<div class="col-md-3"><label class="form-label fw500">交通 (¥)</label><input type="number" class="form-control" name="transport_fee" step="0.01" min="0" value="0" onchange="calcWorkTotal()"></div>
<div class="col-md-3"><label class="form-label fw500">其他 (¥)</label><input type="number" class="form-control" name="other_fee" step="0.01" min="0" value="0" onchange="calcWorkTotal()"></div>
<div class="col-md-3"><label class="form-label fw500">税费 (¥)</label><input type="text" class="form-control wo-readonly" id="woTaxAmount" value="0.00" readonly></div>
<div class="col-md-3"><label class="form-label fw500">税后合计</label><input type="text" class="form-control wo-readonly fw-bold" id="woTotalFee" value="0.00" readonly></div>
<div class="col-md-6">
<label class="form-label fw500">日期</label>
<div class="input-group date-picker-group">
<input type="date" class="form-control" name="work_date" id="workDate">
<button type="button" class="btn-today" onclick="document.getElementById('workDate').value=todayStr()">今天</button>
</div>
</div>
<div class="col-12">
<label class="form-label fw500">备注</label>
<textarea class="form-control" name="remark" rows="3" placeholder="选填"></textarea>
</div>
<div class="col-12">
<label class="form-label fw500">照片</label>
<div class="photo-upload-area" onclick="document.querySelector('input[name=photos]').click()">
  <div class="photo-upload-icon">
    <i class="bi bi-cloud-arrow-up-fill"></i>
  </div>
  <div class="photo-upload-text">
    <strong>点击上传照片</strong>
    <span>或拖拽图片到此处，支持多选</span>
  </div>
  <div class="photo-upload-hint">
    <i class="bi bi-info-circle"></i>
    自动添加日期、客户、地址水印
  </div>
</div>
<input type="file" class="form-control photo-file-input" name="photos" multiple="" accept="image/*" onchange="previewWorkPhotos(event)">
<div id="workPhotoPreview" class="work-photo-preview-grid"></div>
</div>
</div>
<button type="submit" class="btn btn-success w-100 mt-3 py-2 fw-semibold"><i class="bi bi-check-lg me-1"></i> 保存记录</button>
</form>
</div></div></div></div>

<!-- ====== 待办 ====== -->
<div class="tab-pane fade" id="tab-pending">
<div class="container py-3">
<div class="card card-accent-orange shadow-sm mb-3">
<div class="card-header d-flex align-items-center gap-2"><i class="bi bi-plus-circle-fill"></i><span class="fw-semibold">添加待办事项</span></div>
<div class="card-body">
<form id="pendingForm">
<div class="row g-3">
<div class="col-12"><label class="form-label fw500">标题</label><input type="text" class="form-control" name="title" placeholder="选填"></div>
<div class="col-md-4"><label class="form-label fw500">客户 <span class="text-danger">*</span></label><div class="input-group">
<div class="customer-select-wrap">
<input type="text" class="form-control" name="customer_name" required autocomplete="off" placeholder="输入或选择" oninput="showCustomerDropdown(this)" onfocus="showCustomerDropdown(this)">
<div class="customer-dropdown"></div>
</div>
<button type="button" class="btn btn-outline-primary" onclick="openCustomerQuickAdd('pending')" title="添加客户"><i class="bi bi-plus-lg"></i></button>
</div></div>
<div class="col-md-4"><label class="form-label fw500">联系人</label><input type="text" class="form-control" name="contact_name"></div>
<div class="col-md-4"><label class="form-label fw500">联系电话</label><input type="text" class="form-control" name="contact_phone"></div>
<div class="col-12"><label class="form-label fw500">地址</label><input type="text" class="form-control" name="work_address"></div>
<div class="col-md-6"><label class="form-label fw500">类型</label><select class="form-select" name="todo_type"><option>客户报修</option><option>未完成维修</option><option>二次上门</option><option>待派工</option><option>待报价</option><option>施工安排</option><option>待收款</option><option>待回访</option><option>材料采购</option><option>设备更换</option><option>项目验收</option><option>其他事项</option></select></div>
<div class="col-md-6"><label class="form-label fw500">优先级</label><select class="form-select" name="priority"><option value="normal">普通</option><option value="urgent">紧急</option><option value="high">高优先级</option><option value="low">低优先级</option></select></div>
<div class="col-md-6"><label class="form-label fw500">人员</label>
<select class="form-select" name="staff_name"><option value="">请选择</option></select></div>
<div class="col-md-6"><label class="form-label fw500">提醒日期 <span class="text-danger">*</span></label>
<div class="input-group date-picker-group"><input type="date" class="form-control" name="reminder_date" required><button type="button" class="btn-today" onclick="this.previousElementSibling.value=todayStr()">今天</button></div></div>
<div class="col-12"><label class="form-label fw500">内容 <span class="text-danger">*</span></label><textarea class="form-control" name="work_content" rows="3" required></textarea></div>
</div>
<button type="submit" class="btn btn-warning w-100 mt-3 py-2 fw-semibold"><i class="bi bi-plus-lg me-1"></i> 添加待办</button>
</form>
</div></div>
<div class="card card-accent-blue shadow-sm">
<div class="card-header d-flex align-items-center gap-2 flex-wrap">
<i class="bi bi-list-check"></i><span class="fw-semibold">待办列表</span>
<div class="pending-filter-bar ms-auto">
<button class="pending-filter-btn active" data-filter="all" onclick="filterPending('all')">全部</button>
<button class="pending-filter-btn" data-filter="urgent" onclick="filterPending('urgent')"><i class="bi bi-exclamation-triangle-fill me-1"></i>紧急</button>
<button class="pending-filter-btn" data-filter="overdue" onclick="filterPending('overdue')"><i class="bi bi-clock-history me-1"></i>过期</button>
<button class="pending-filter-btn" data-filter="today" onclick="filterPending('today')"><i class="bi bi-calendar-check me-1"></i>今天</button>
</div>
<span class="badge bg-danger rounded-pill" id="pendingCountBadge">0</span>
</div>
<div class="card-body" id="pendingList"><div class="empty-state py-4">加载中...</div></div>
</div></div></div>



<!-- ====== 工资记录 ====== -->
<div class="tab-pane fade" id="tab-salary">
<div class="container py-3">
<div class="card card-accent-green shadow-sm mb-3">
<div class="card-header d-flex align-items-center gap-2"><i class="bi bi-cash-coin"></i><span class="fw-semibold">新增工资记录</span></div>
<div class="card-body">
<form id="salaryForm">
<div class="row g-2">
<div class="col-md-3"><label class="form-label fw500">员工</label><select class="form-select" name="staff_name" id="salaryStaff" required><option value="">请选择</option></select></div>
<div class="col-md-2"><label class="form-label fw500">工作日期</label><input type="date" class="form-control" name="work_date" id="salaryDate"></div>
<div class="col-md-2"><label class="form-label fw500">日薪</label><input type="number" class="form-control" name="daily_wage" id="salaryDaily" min="0" step="1" value="0" oninput="calcSalaryForm()"></div>
<div class="col-md-2"><label class="form-label fw500">天数/工时</label><input type="number" class="form-control" name="work_units" id="salaryUnits" min="0" step="0.5" value="1" oninput="calcSalaryForm()"></div>
<div class="col-md-3"><label class="form-label fw500">应发金额</label><input type="text" class="form-control fw-bold" id="salaryPayable" value="0.00" readonly></div>
<div class="col-md-3"><label class="form-label fw500">业务类型</label><select class="form-select" name="business_type"><option>其他</option><option>施工记录</option><option>维修工单</option></select></div>
<div class="col-md-3"><label class="form-label fw500">业务编号</label><input type="text" class="form-control" name="business_no"></div>
<div class="col-md-3"><label class="form-label fw500">客户</label><input type="text" class="form-control" name="customer_name"></div>
<div class="col-md-3"><label class="form-label fw500">支付方式</label><select class="form-select" name="payment_method"><option value="">未选择</option><option>现金</option><option>微信</option><option>支付宝</option><option>转账</option></select></div>
<div class="col-12"><label class="form-label fw500">工作内容/备注</label><input type="text" class="form-control" name="work_content"></div>
</div>
<button type="submit" class="btn btn-success w-100 mt-3"><i class="bi bi-check-lg me-1"></i>保存工资记录</button>
</form></div></div>
<div class="card shadow-sm mb-3"><div class="card-body">
<div class="row g-2 align-items-end">
<div class="col-md-3"><label class="form-label fw500">月份</label><input type="month" class="form-control" id="salaryMonth"></div>
<div class="col-md-3"><label class="form-label fw500">状态</label><select class="form-select" id="salaryStatus"><option value="">全部</option><option value="unsettled">未结算</option><option value="settled">已结算</option></select></div>
<div class="col-md-3"><button class="btn btn-primary w-100" onclick="loadSalaries()">查询工资</button></div>
</div></div></div>
<div id="salarySummary" class="row g-3 mb-3"></div>
<div id="salaryList"></div>
</div></div>

<!-- ====== 查询 ====== -->
<div class="tab-pane fade" id="tab-query">
<div class="container py-3">
<div class="card card-accent-blue shadow-sm mb-3">
<div class="card-header d-flex align-items-center gap-2"><i class="bi bi-funnel-fill"></i><span class="fw-semibold">查询条件</span></div>
<div class="card-body">
<div class="row g-2">
<div class="col-md-4"><label class="form-label fw500">客户</label><div class="customer-select-wrap">
<input type="text" class="form-control" id="qCustomerName" autocomplete="off" placeholder="输入或选择" oninput="showCustomerDropdown(this)" onfocus="showCustomerDropdown(this)">
<div class="customer-dropdown"></div>
</div></div>
<div class="col-md-3"><label class="form-label fw500">人员</label><select class="form-select" id="qStaffName"><option value="">不限</option></select></div>
<div class="col-md-5">
<label class="form-label fw500">日期范围</label>
<div class="query-date-presets">
<button class="btn btn-outline-primary" onclick="setQueryRange('today')">今天</button>
<button class="btn btn-outline-primary" onclick="setQueryRange('thisWeek')">本周</button>
<button class="btn btn-outline-primary" onclick="setQueryRange('thisMonth')">本月</button>
<button class="btn btn-outline-primary" onclick="setQueryRange('lastMonth')">上月</button>
</div>
<div class="query-date-range">
<label class="small text-muted">从</label>
<input type="date" class="form-control form-control-sm is-4" id="qDateStart">
<label class="small text-muted">至</label>
<input type="date" class="form-control form-control-sm is-4" id="qDateEnd">
</div>
</div>
<div class="col-12">
<div class="query-chipbar" aria-label="快捷筛选">
<button class="query-chip active" data-qtype="" onclick="setQueryType('', this)">全部工单</button>
<button class="query-chip" data-qtype="construction" onclick="setQueryType('construction', this)">施工记录</button>
<button class="query-chip" data-qtype="repair" onclick="setQueryType('repair', this)">维修工单</button>
<button class="query-chip" onclick="setQueryPayment('unpaid', this)">未收款</button>
<button class="query-chip" onclick="setQueryPayment('partial', this)">部分收款</button>
<button class="query-chip" onclick="setQueryPayment('monthly', this)">月结</button>
<button class="query-chip" onclick="setQueryStatus('callback', this)">待回访</button>
<button class="query-chip" onclick="setQueryStatus('settlement', this)">待结算</button>
</div>
</div>
<div class="col-12 mt-2 query-actions">
<button class="btn btn-primary me-2" onclick="queryRecords()"><i class="bi bi-search me-1"></i>查询</button>
<button class="btn btn-outline-secondary" onclick="resetQuery()"><i class="bi bi-arrow-counterclockwise me-1"></i>重置</button>
<button class="btn btn-success me-2" onclick="exportRecords()"><i class="bi bi-download me-1"></i>CSV</button>
<button class="btn btn-outline-primary" onclick="exportPdfRange()"><i class="bi bi-filetype-pdf me-1"></i>PDF</button>
</div>
</div></div></div>
<div id="querySummary" class="query-summary-grid"></div>
<div id="queryResults"></div>
</div></div>

<!-- ====== 客户 ====== -->
<div class="tab-pane fade" id="tab-customer">
<div class="container py-3">
<div class="card card-accent-purple shadow-sm mb-3">
<div class="card-header d-flex align-items-center gap-2"><i class="bi bi-person-plus-fill"></i><span class="fw-semibold">添加客户</span></div>
<div class="card-body">
<form id="customerForm">
<div class="row g-2">
<div class="col-md-3"><input type="text" class="form-control" name="short_name" placeholder="客户简称 *" required></div>
<div class="col-md-5"><input type="text" class="form-control" name="full_name" placeholder="客户全称"></div>
<div class="col-md-4"><input type="text" class="form-control" name="credit_code" placeholder="统一社会信用代码"></div>
<div class="col-md-3"><input type="text" class="form-control" name="contact_name" placeholder="联系人"></div>
<div class="col-md-3"><input type="text" class="form-control" name="phone" placeholder="电话"></div>
<div class="col-md-5"><input type="text" class="form-control" name="address" placeholder="地址"></div>
<div class="col-md-4"><input type="text" class="form-control" name="remark" placeholder="备注"></div>
<div class="col-md-2"><button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i> 添加</button></div>
</div></form></div></div>
<div class="card card-accent-purple shadow-sm mb-3">
<div class="card-header d-flex align-items-center gap-2"><i class="bi bi-search"></i><span class="fw-semibold">搜索</span></div>
<div class="card-body"><input type="text" class="form-control" id="customerSearch" placeholder="输入简称、全称、联系人或统一信用代码搜索…" oninput="debouncedLoadCustomers()"></div></div>
<div id="customerListContainer"></div></div></div>

<!-- ====== 统计 ====== -->
<div class="tab-pane fade" id="tab-stats">
<div class="container py-3">
<div class="card card-accent-green shadow-sm mb-3">
<div class="card-header d-flex align-items-center gap-2"><i class="bi bi-calendar-range-fill"></i><span class="fw-semibold">统计周期</span></div>
<div class="card-body">
<div class="row g-2 align-items-end">
<div class="col-md-3"><label class="form-label fw500">开始</label><input type="date" class="form-control" id="statsStart"></div>
<div class="col-md-3"><label class="form-label fw500">结束</label><input type="date" class="form-control" id="statsEnd"></div>
<div class="col-md-3">
<div class="btn-group btn-group-sm w-100">
<button class="btn btn-outline-primary" onclick="setStatsRange('thisMonth')">本月</button>
<button class="btn btn-outline-primary" onclick="setStatsRange('lastMonth')">上月</button>
<button class="btn btn-outline-primary" onclick="setStatsRange('thisYear')">今年</button>
</div>
</div>
<div class="col-md-3"><button class="btn btn-primary w-100" onclick="loadStatistics()"><i class="bi bi-arrow-repeat me-1"></i>刷新</button></div>
</div></div></div>
<div id="statsContent"></div></div></div>

<!-- ====== 员工 ====== -->
<div class="tab-pane fade" id="tab-staff">
<div class="container py-3">
<div class="card card-accent-gray shadow-sm mb-3">
<div class="card-header d-flex align-items-center gap-2"><i class="bi bi-person-plus-fill"></i><span class="fw-semibold">添加员工</span></div>
<div class="card-body">
<form id="staffForm">
<div class="row g-2">
<div class="col-md-3 col-6"><input type="text" class="form-control" name="name" placeholder="姓名 *" required></div>
<div class="col-md-3 col-6"><input type="text" class="form-control" name="phone" placeholder="电话"></div>
<div class="col-md-3 col-6">
<select class="form-select" name="staff_type" id="staffAddType" onchange="onStaffAddTypeChange()">
<option value="fixed">固定工</option>
<option value="temp">临时工</option>
</select>
</div>
<div class="col-md-3 col-6"><input type="text" class="form-control" name="position" placeholder="工种/职位"></div>
</div>
<div class="row g-2 mt-1">
<div class="col-md-3 col-6" id="staffAddMonthlyCol"><input type="number" class="form-control" name="monthly_salary" step="1" min="0" placeholder="月薪(¥)" oninput="staffAddCalcDaily()"></div>
<div class="col-md-3 col-6"><input type="number" class="form-control" name="daily_wage" step="1" min="0" placeholder="日薪(¥)" id="staffAddDaily" oninput="staffAddCalcMonthly()"></div>
<div class="col-md-3 col-6"><input type="text" class="form-control" name="id_card" placeholder="身份证号"></div>
<div class="col-md-3 col-6"><input type="date" class="form-control" name="hire_date"></div>
</div>
<div class="row g-2 mt-1">
<div class="col-md-4"><input type="text" class="form-control" name="project" placeholder="所属项目"></div>
<div class="col-md-6"><input type="text" class="form-control" name="remark" placeholder="备注"></div>
<div class="col-md-2"><button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-lg"></i></button></div>
</div>
<!-- 固定工：开通登录账号 -->
<div class="row g-2 mt-1 is-0" id="staffAddAccountSection">
<div class="col-12"><hr class="my-1"><strong class="small"><i class="bi bi-shield me-1"></i>开通登录账号（固定工可选）</strong></div>
<div class="col-md-4"><input type="text" class="form-control" name="acc_username" placeholder="用户名"></div>
<div class="col-md-4"><input type="password" class="form-control" name="acc_password" placeholder="密码（留空不开通）"></div>
<div class="col-md-4">
<select class="form-select" name="acc_role"><option value="worker">员工</option><option value="admin">管理员</option></select>
</div>
</div>
<!-- 身份证照片上传（添加后显示） -->
<div id="staffIdPhotoSection" class="mt-2 is-0">
<div class="d-flex align-items-center gap-2">
<strong class="small">身份证照片:</strong>
<img id="staffIdPhotoPreview" src="" class="is-2">
<button class="btn btn-outline-primary btn-sm" onclick="document.getElementById('staffIdPhotoInput').click()"><i class="bi bi-upload"></i> 上传</button>
<input type="file" id="staffIdPhotoInput" accept="image/*" onchange="uploadStaffPhoto('id_photo')" class="is-0">
</div>
<div class="d-flex align-items-center gap-2 mt-1">
<strong class="small">职业证书照片:</strong>
<img id="staffCertPhotoPreview" src="" class="is-2">
<button class="btn btn-outline-primary btn-sm" onclick="document.getElementById('staffCertPhotoInput').click()"><i class="bi bi-upload"></i> 上传</button>
<input type="file" id="staffCertPhotoInput" accept="image/*" onchange="uploadStaffPhoto('cert_photo')" class="is-0">
</form>
</div>
</div></div></div>
<div id="staffListContainer"></div></div></div>

<!-- ====== 员工账户管理弹窗 ====== -->
<div class="modal fade" id="staffUserModal" tabindex="-1">
<div class="modal-dialog"><div class="modal-content">
<div class="modal-header"><h5 class="modal-title" id="staffUserModalTitle">员工账户管理</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
<div class="modal-body">
<form id="staffUserForm">
<input type="hidden" name="staff_name" id="suStaffName">
<input type="hidden" name="staff_id" id="suStaffId">
<div class="mb-3"><label class="form-label fw500">用户名</label><input type="text" class="form-control" name="username" id="suUsername" placeholder="登录用户名"></div>
<div class="mb-3"><label class="form-label fw500">密码</label><input type="password" class="form-control" name="password" id="suPassword" placeholder="最少4位" minlength="4"></div>
<div class="mb-3"><label class="form-label fw500">权限</label>
<div class="d-flex flex-column gap-2 p-3 bg-light rounded is-13">
<label class="btn btn-outline-secondary text-start d-flex align-items-center gap-2 is-14" id="suAdminToggle">
<input type="checkbox" id="suAdminCheck" onchange="onSuRoleChange()" class="is-15">
<div class="d-flex flex-column"><strong>管理员</strong><small class="text-muted">员工管理、账户管理、系统设置、删除数据、查看全部内容</small></div>
</label>
<div class="ps-3 border-start border-2 is-16">
<div class="py-1"><span class="badge bg-info me-2 is-1">✓</span> 工作记录（增删改查）</div>
<div class="py-1"><span class="badge bg-info me-2 is-1">✓</span> 客户管理</div>
<div class="py-1"><span class="badge bg-info me-2 is-1">✓</span> 待办管理</div>
<div class="py-1"><span class="badge bg-info me-2 is-1">✓</span> 统计查看</div>
<div id="suAdminExtras" class="is-0">
<div class="py-1"><span class="badge bg-danger me-2 is-1">✦</span> 员工管理（增删改）</div>
<div class="py-1"><span class="badge bg-danger me-2 is-1">✦</span> 登录账户管理</div>
<div class="py-1"><span class="badge bg-danger me-2 is-1">✦</span> 删除任意记录</div>
</div>
</div>
</div>
<input type="hidden" name="role" id="suRole" value="worker"></div>
<div class="d-flex gap-2"><button type="submit" class="btn btn-primary" id="suSubmitBtn"><i class="bi bi-check-lg me-1"></i>保存</button><button type="button" class="btn btn-outline-danger is-0" id="suDeleteBtn" onclick="deleteStaffUser()"><i class="bi bi-trash me-1"></i>删除账户</button></div>
</form>
</div></div></div></div>

<!-- ====== 操作日志 ====== -->
<div class="tab-pane fade" id="tab-oplogs">
<div class="container py-3">
<div class="card card-accent-gray shadow-sm mb-3">
<div class="card-header d-flex align-items-center justify-between gap-2">
<i class="bi bi-clock-history"></i><span class="fw-semibold">操作日志</span>
</div>
<div class="card-body">
<div class="row g-2 mb-3">
<div class="col-md-2 col-6">
<select class="form-select" id="oplogTypeFilter" onchange="loadOpLogs(1)">
<option value="">全部类型</option>
<option value="work_record">工单</option>
<option value="pending_work">待办</option>
</select>
</div>
<div class="col-md-2 col-6">
<select class="form-select" id="oplogActionFilter" onchange="loadOpLogs(1)">
<option value="">全部操作</option>
<option value="update">编辑</option>
<option value="delete">删除</option>
</select>
</div>
<div class="col-md-4 col-12">
<input type="text" class="form-control" id="oplogKeyword" placeholder="搜索客户名称/标题..." onkeyup="if(event.key==='Enter')loadOpLogs(1)">
</div>
<div class="col-md-2 col-6">
<button class="btn btn-primary w-100" onclick="loadOpLogs(1)"><i class="bi bi-search me-1"></i>搜索</button>
</div>
<div class="col-md-2 col-6">
<button class="btn btn-outline-secondary w-100" onclick="loadOpLogs(1)"><i class="bi bi-arrow-repeat me-1"></i>刷新</button>
</div>
</div>

<div class="row g-2 mb-3">
<div class="col-md-3 col-6">
<div class="p-2 rounded" style="background:var(--ry-surface-2,#f5f5f5)">
<div class="text-muted small">日志总数</div>
<div class="fw-bold fs-5" id="oplogTotal">--</div>
</div>
</div>
<div class="col-md-3 col-6">
<div class="p-2 rounded" style="background:var(--ry-surface-2,#f5f5f5)">
<div class="text-muted small">待清理</div>
<div class="fw-bold fs-5 text-warning" id="oplogExpired">--</div>
</div>
</div>
<div class="col-md-4 col-6">
<div class="p-2 rounded" style="background:var(--ry-surface-2,#f5f5f5)">
<div class="text-muted small mb-1">保留天数设置</div>
<div class="d-flex gap-2">
<input type="number" class="form-control form-control-sm" id="oplogRetentionDays" value="90" min="7" max="365" style="width:100px">
<button class="btn btn-sm btn-outline-primary" onclick="saveRetentionDays()">保存</button>
</div>
</div>
</div>
<div class="col-md-2 col-6">
<div class="p-2 rounded" style="background:var(--ry-surface-2,#f5f5f5)">
<div class="text-muted small mb-1">清理操作</div>
<button class="btn btn-sm btn-danger w-100" onclick="cleanupOplogs()"><i class="bi bi-trash me-1"></i>清理过期</button>
</div>
</div>
</div>

<div id="oplogList"><div class="text-muted small py-4 text-center">加载中...</div></div>
<div id="oplogPagination" class="mt-3"></div>
</div>
</div>
</div>
</div>

